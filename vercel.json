{
  "version": 2,
  "public": true,
  "cleanUrls": true,
  "buildCommand": null,
  "installCommand": null,
  "outputDirectory": "public",
  "rewrites": [
    { "source": "/room/(.*)", "destination": "/index.html" },
    { "source": "/(.*)", "destination": "/$1" }
  ],
  "redirects": [
    { "source": "/room", "destination": "/", "permanent": false }
  ]
}
